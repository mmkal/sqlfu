{
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../../../dist/vendor",
    "allowJs": true,
    "noCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "./**/*.ts",
    "../code-block-writer/**/*.ts",
    "../small-utils.ts",
    "../typesql-parser/**/*.ts",
    "../antlr4/**/*.js"
  ],
  "exclude": [
    "../../../../../node_modules",
    "../../../dist"
  ]
}
