{
  "name": "sqlfu",
  "version": "0.0.3-7",
  "description": "sql-first client, migrator, diff engine, typescript generator, formatter, and ui.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmkal/sqlfu.git"
  },
  "bin": {
    "sqlfu": "./bin/sqlfu.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/index.ts",
    "./analyze": "./src/analyze.ts",
    "./api": "./src/api/exports.ts",
    "./api/core": "./src/api/core.ts",
    "./api/sync": "./src/api/sync.ts",
    "./cloudflare": "./src/cloudflare/exports.ts",
    "./better-auth": "./src/better-auth.ts",
    "./lint-plugin": "./src/lint-plugin.ts",
    "./outbox": "./src/outbox/index.ts",
    "./ui": "./src/ui/server.ts",
    "./ui/browser": "./src/ui/browser.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./analyze": {
        "types": "./dist/analyze.d.ts",
        "default": "./dist/analyze.js"
      },
      "./api": {
        "types": "./dist/api/exports.d.ts",
        "default": "./dist/api/exports.js"
      },
      "./api/core": {
        "types": "./dist/api/core.d.ts",
        "default": "./dist/api/core.js"
      },
      "./api/sync": {
        "types": "./dist/api/sync.d.ts",
        "default": "./dist/api/sync.js"
      },
      "./cloudflare": {
        "types": "./dist/cloudflare/exports.d.ts",
        "default": "./dist/cloudflare/exports.js"
      },
      "./better-auth": {
        "types": "./dist/better-auth.d.ts",
        "default": "./dist/better-auth.js"
      },
      "./lint-plugin": {
        "types": "./dist/lint-plugin.d.ts",
        "default": "./dist/lint-plugin.js"
      },
      "./outbox": {
        "types": "./dist/outbox/index.d.ts",
        "default": "./dist/outbox/index.js"
      },
      "./ui": {
        "types": "./dist/ui/server.d.ts",
        "default": "./dist/ui/server.js"
      },
      "./ui/browser": {
        "types": "./dist/ui/browser.d.ts",
        "default": "./dist/ui/browser.js"
      }
    }
  },
  "scripts": {
    "build": "pnpm run build:runtime && pnpm run build:vendor-typesql && pnpm run build:bundle-vendor",
    "build:runtime": "rm -f dist/api.js dist/api.d.ts dist/node.js dist/node.d.ts && tsgo -p tsconfig.build.json",
    "build:vendor-typesql": "rm -rf dist/vendor/code-block-writer dist/vendor/sqlfu-sqlite-parser dist/vendor/typesql && tsgo -p src/vendor/typesql/tsconfig.json",
    "build:bundle-vendor": "tsx scripts/bundle-vendor.ts",
    "typecheck": "tsgo -p tsconfig.typecheck.json && pnpm run typecheck:vendor-typesql",
    "typecheck:vendor-typesql": "tsgo -p src/vendor/typesql/tsconfig.json --noEmit",
    "test": "pnpm run test:node",
    "test:node": "vitest",
    "generate": "node ./dist/cli.js generate",
    "cli": "node ./dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@orpc/server": "^1.13.13",
    "trpc-cli": "^0.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@effect/sql": "^0.51.1",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@hono/node-server": "^1.19.14",
    "@libsql/client": "^0.17.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@orpc/client": "1.13.13",
    "@sentry/node": "^10.49.0",
    "@sqlite.org/sqlite-wasm": "3.51.2-build9",
    "@tursodatabase/database": "^0.5.3",
    "@tursodatabase/serverless": "^1.1.0",
    "@tursodatabase/sync": "^0.5.3",
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.8",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260414.1",
    "arktype": "^2.2.0",
    "auth": "1.6.9",
    "better-auth": "1.6.9",
    "better-sqlite3": "^12.8.0",
    "dedent": "^1.7.2",
    "devalue": "^5.7.1",
    "dotenv": "^17.4.2",
    "effect": "^3.21.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.36.0",
    "execa": "^9.6.1",
    "hono": "^4.12.14",
    "hot-shots": "^14.3.1",
    "libsql": "0.5.29",
    "miniflare": "^4.20260409.0",
    "playwright": "^1.59.1",
    "posthog-node": "^5.29.2",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "valibot": "^1.3.1",
    "vite": "^7.1.12",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "@effect/sql": "^0.51.1",
    "@sqlfu/ui": "workspace:*",
    "better-auth": "^1.6.9",
    "effect": "^3.21.2 || ^4.0.0-beta.60"
  },
  "peerDependenciesMeta": {
    "@effect/sql": {
      "optional": true
    },
    "@sqlfu/ui": {
      "optional": true
    },
    "better-auth": {
      "optional": true
    },
    "effect": {
      "optional": true
    }
  }
}
