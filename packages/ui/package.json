{
  "name": "@sqlfu/ui",
  "version": "0.0.3-1",
  "description": "sqlfu's web UI. Companion to the sqlfu package; version-matched so `sqlfu --ui` can serve a local UI that aligns with your server.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmkal/sqlfu.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "pnpm exec tsx test/start-server.ts dev-project --dev",
    "demo": "vite --open /?demo=1",
    "hosted-sim": "pnpm exec tsx test/hosted-sim.ts",
    "build": "vite build",
    "test:node": "vitest run src/runtime.test.ts src/startup-error.test.ts",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "playwright test"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@orpc/client": "1.13.13",
    "@orpc/server": "1.13.13",
    "@orpc/tanstack-query": "1.13.13",
    "@radix-ui/react-dialog": "^1.1.15",
    "@rjsf/core": "^6.0.1",
    "@rjsf/utils": "^6.4.2",
    "@rjsf/validator-ajv8": "^6.0.1",
    "@silevis/reactgrid": "^4.1.17",
    "@sqlite.org/sqlite-wasm": "3.51.2-build9",
    "@tanstack/react-query": "^5.90.5",
    "@uiw/react-codemirror": "^4.25.9",
    "clsx": "^2.1.1",
    "itty-time": "^2.0.2",
    "react": "^19.2.0",
    "react-codemirror-merge": "^4.25.9",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "semver": "^7.7.4",
    "tailwind-merge": "^3.5.0",
    "use-local-storage-state": "^19.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/semver": "^7.7.0",
    "@vitejs/plugin-react": "^5.1.0",
    "sqlfu": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@typescript/native-preview": "^7.0.0-dev.20260414.1",
    "vite": "^7.1.12",
    "vitest": "^4.1.1"
  }
}
