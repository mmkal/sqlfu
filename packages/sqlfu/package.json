{
  "name": "sqlfu",
  "version": "0.0.2-3",
  "description": "sql-first client, migrator, diff engine, typescript generator, formatter, and ui.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmkal/sqlfu.git"
  },
  "type": "module",
  "bin": {
    "sqlfu": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./client": "./src/client.ts",
    "./api": "./src/api.ts",
    "./cli": "./src/cli.ts",
    "./ui": {
      "browser": "./src/ui/browser.ts",
      "default": "./src/ui/index.ts"
    },
    "./ui/browser": "./src/ui/browser.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./browser": {
        "types": "./dist/browser.d.ts",
        "default": "./dist/browser.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      },
      "./api": {
        "types": "./dist/api.d.ts",
        "default": "./dist/api.js"
      },
      "./cli": {
        "types": "./dist/cli.d.ts",
        "default": "./dist/cli.js"
      },
      "./ui": {
        "types": "./dist/ui/index.d.ts",
        "browser": "./dist/ui/browser.js",
        "default": "./dist/ui/index.js"
      },
      "./ui/browser": {
        "types": "./dist/ui/browser.d.ts",
        "default": "./dist/ui/browser.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:runtime && pnpm run build:vendor-typesql",
    "build:runtime": "tsc -p tsconfig.build.json",
    "build:vendor-typesql": "rm -rf dist/vendor && tsc -p src/vendor/typesql/tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json && pnpm run typecheck:vendor-typesql",
    "typecheck:vendor-typesql": "tsc -p src/vendor/typesql/tsconfig.json --noEmit",
    "test": "pnpm run test:node",
    "test:node": "vitest",
    "generate": "node ./dist/cli.js generate",
    "cli": "node ./dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@orpc/server": "^1.13.13",
    "nearley": "^2.20.1",
    "trpc-cli": "^0.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@libsql/client": "^0.17.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@orpc/client": "1.13.13",
    "@types/node": "^24.5.2",
    "better-sqlite3": "^12.8.0",
    "dedent": "^1.7.2",
    "devalue": "^5.7.1",
    "execa": "^9.6.1",
    "hono": "^4.12.14",
    "libsql": "0.5.29",
    "miniflare": "^4.20260409.0",
    "playwright": "^1.59.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.1"
  }
}
