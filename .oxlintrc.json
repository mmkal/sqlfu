{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "vitest"],
  "jsPlugins": [
    {"name": "sqlfu", "specifier": "./packages/sqlfu/dist/lint-plugin.js"}
  ],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/.sqlfu/**",
    "**/.typesql/**",
    "**/node_modules/**",
    "**/.generated/**",
    "packages/sqlfu/src/vendor/**"
  ],
  "rules": {
    "sqlfu/no-unnamed-inline-sql": "error",
    "sqlfu/format-sql": "error"
  },
  "env": {
    "builtin": true,
    "node": true,
    "browser": true
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/test/**", "**/tests/**"],
      "rules": {
        "no-unused-expressions": "off",
        "sqlfu/format-sql": "off"
      }
    }
  ]
}
