{
  "name": "sqlfu",
  "version": "0.0.0",
  "description": "Slim SQLite tooling around libsql, D1, typesql, and sqldef",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmkal/sqlfu.git"
  },
  "type": "module",
  "bin": {
    "sqlfu": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./api": "./dist/api.js",
    "./cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "sql",
    "definitions.sql",
    "typesql.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "pnpm run test:node && pnpm run test:bun",
    "test:node": "vitest",
    "test:bun": "bun test ./test/buntest.ts",
    "generate": "node ./dist/cli.js generate",
    "cli": "node ./dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@libsql/client": "^0.17.2",
    "@orpc/server": "^1.13.13",
    "dbmate": "^2.31.0",
    "trpc-cli": "^0.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "better-sqlite3": "^12.8.0",
    "bun-types": "1.3.11",
    "dedent": "^1.7.2",
    "execa": "^9.6.1",
    "libsql": "0.5.29",
    "miniflare": "^4.20260409.0",
    "playwright": "^1.59.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "typesql-cli": "^0.22.0",
    "vitest": "^4.1.1"
  }
}
