{
  "name": "sqlfu",
  "version": "0.0.0",
  "description": "Slim SQLite tooling around native SQLite, D1, typesql, and sqldef",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmkal/sqlfu.git"
  },
  "type": "module",
  "bin": {
    "sqlfu": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./api": "./dist/api.js",
    "./cli": "./dist/cli.js",
    "./naming": "./src/core/naming.ts",
    "./experimental": "./src/experimental.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:runtime && pnpm run build:vendor-typesql",
    "build:runtime": "tsc -p tsconfig.build.json",
    "build:vendor-typesql": "rm -rf dist/vendor && tsc -p src/vendor/typesql/tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json && pnpm run typecheck:vendor-typesql",
    "typecheck:vendor-typesql": "tsc -p src/vendor/typesql/tsconfig.json --noEmit",
    "test": "pnpm run test:node",
    "test:node": "vitest",
    "generate": "node ./dist/cli.js generate",
    "cli": "node ./dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@orpc/server": "^1.13.13",
    "trpc-cli": "^0.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@types/node": "^24.5.2",
    "better-sqlite3": "^12.8.0",
    "dedent": "^1.7.2",
    "devalue": "^5.7.1",
    "execa": "^9.6.1",
    "libsql": "0.5.29",
    "miniflare": "^4.20260409.0",
    "playwright": "^1.59.1",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
