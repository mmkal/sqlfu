{
  "name": "sqlfu-workspace",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/iterate/sqlfu"
  },
  "scripts": {
    "dev-project": "tsx packages/sqlfu/src/cli --config packages/ui/test/projects/dev-project/sqlfu.config.ts",
    "dev": "pnpm --filter @sqlfu/ui dev",
    "demo": "pnpm --filter @sqlfu/ui demo",
    "sync:root-readme": "tsx scripts/sync-root-readme.ts sync",
    "sync:root-readme:check": "tsx scripts/sync-root-readme.ts check",
    "sync:root-readme:pre-commit": "tsx scripts/sync-root-readme.ts pre-commit",
    "hosted-sim": "pnpm --filter @sqlfu/ui build && pnpm --filter @sqlfu/ui hosted-sim -- --skip-build",
    "sqlfu": "cd packages/sqlfu && pnpm",
    "ui": "cd packages/ui && pnpm",
    "pg": "cd packages/pg && pnpm",
    "website": "pnpm --filter sqlfu-website dev",
    "infra": "pnpm exec alchemy run alchemy.run.mts",
    "deploy": "pnpm build && pnpm exec alchemy deploy alchemy.run.mts",
    "destroy": "pnpm exec alchemy destroy alchemy.run.mts",
    "build": "pnpm --filter sqlfu build && pnpm --filter @sqlfu/pg build && pnpm --filter @sqlfu/ui build && pnpm --filter sqlfu-website build",
    "build:website": "pnpm --filter sqlfu-website build",
    "test": "pnpm --recursive --workspace-concurrency=1 test",
    "typecheck": "pnpm --filter sqlfu typecheck && pnpm --filter @sqlfu/pg typecheck && pnpm --filter @sqlfu/ui typecheck",
    "generate": "pnpm --filter sqlfu generate",
    "cli": "pnpm --filter sqlfu cli",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "alchemy": "^0.93.7",
    "eslint": "^9.39.4",
    "eslint-plugin-unicorn": "^64.0.0",
    "oxfmt": "^0.45.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.59.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm sync:root-readme:pre-commit"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.1"
}
