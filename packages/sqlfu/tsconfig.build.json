{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",
    "verbatimModuleSyntax": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/vendor/code-block-writer/**/*",
    "src/vendor/typesql/**/*",
    "src/vendor/sqlfu-sqlite-parser/**/*"
  ]
}
